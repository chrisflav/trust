# Copy to `.env` beside this file, fill in, then `docker compose up --build`.

# openssl rand -hex 32
SESSION_SECRET=

# github.com/settings/developers → New OAuth App
#   Homepage URL:               http://localhost:8099
#   Authorization callback URL: http://localhost:8099/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Where this server is reachable; must match the OAuth callback's origin.
PUBLIC_URL=http://localhost:8099
# Where the frontend runs — the container below, by default.  Sign-in returns
# here, and it is the one origin allowed to call the API with cookies; a
# mismatch is silent and looks exactly like "nobody has certified anything".
APP_URL=http://localhost:5174

# Set true when serving over HTTPS, so the session cookie is not sent in clear.
COOKIE_SECURE=false

# Loopback unless you really mean otherwise: behind Apache these ports should
# not be reachable from outside the host.  Set 0.0.0.0 only to expose directly.
BIND_ADDR=127.0.0.1
SERVER_PORT=8099
# The frontend container.  5173 is left free for `npm run dev`.
WEB_PORT=5174
POSTGRES_PASSWORD=trust

# ---------------------------------------------------------------------------
# Deploying behind Apache on one domain (see deploy/trust.merten.dev.conf):
#
#   PUBLIC_URL=https://trust.merten.dev
#   APP_URL=https://trust.merten.dev
#   COOKIE_SECURE=true
#
# and the OAuth App's callback becomes
#   https://trust.merten.dev/auth/github/callback
#
# One origin for both means no CORS at all and a first-party session cookie.
# The frontend bakes PUBLIC_URL in at build time, so changing it needs
# `docker compose up --build web`.

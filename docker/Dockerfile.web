# Build the frontend and serve it as static files.
#
# `VITE_TRUST_SERVER` is baked in at build time, which is how Vite works: it is
# substituted into the bundle rather than read at run time.  Changing it means
# rebuilding this image.

FROM node:22-alpine AS build
WORKDIR /app
COPY web/package.json web/package-lock.json* ./
RUN npm install --no-audit --no-fund
COPY web/ ./
ARG VITE_TRUST_SERVER=""
ENV VITE_TRUST_SERVER=$VITE_TRUST_SERVER
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --start-period=5s --retries=5 \
  CMD wget -q -O /dev/null http://127.0.0.1/ || exit 1
